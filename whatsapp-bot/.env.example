# Préfixe des commandes WhatsApp
PREFIX=!

# Nom affiché du bot
BOT_NAME=DBL Tournois

# API centrale : source de vérité unique (cf. DESIGN.md)
API_BASE_URL=http://localhost:3000
API_KEY=

# Clé admin de l'API (doit correspondre à ADMIN_KEY de l'API) pour les commandes admin
ADMIN_KEY=

# Dossier de session WhatsApp (multi-file auth state de Baileys)
SESSION_PATH=./whatsapp_auth

# Connexion par CODE d'appairage (prioritaire sur le QR).
# Numéro du bot avec indicatif pays, chiffres uniquement (ex: 22990000001).
WHATSAPP_NUMBER=
USE_PAIRING_CODE=true

# Numéros admins autorisés à changer l'affichage (séparés par des virgules)
# Ex: ADMIN_NUMBERS=22990000001,22990000002  (vide = tout le monde)
ADMIN_NUMBERS=
