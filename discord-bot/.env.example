# --- Discord ---
# Token du bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=
# Application (Client) ID : Developer Portal > General Information
DISCORD_CLIENT_ID=
# ID du serveur de test (commandes instantanées). Vide = global (~1h de propagation)
DISCORD_GUILD_ID=

BOT_NAME=DBL Tournois

# --- API centrale ---
API_BASE_URL=http://localhost:3000
API_KEY=
# Doit correspondre à ADMIN_KEY de l'API
ADMIN_KEY=

# IDs Discord admins (séparés par des virgules). Vide = les admins du serveur
# (permission Administrateur) suffisent ; en dev, tout le monde est admin.
ADMIN_IDS=
